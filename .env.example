# Polygon WebSocket RPC endpoint
# Get one from: QuickNode, Alchemy, Infura, or other Polygon RPC providers
POLYGON_WSS_URL=wss://your-polygon-wss-endpoint

# Path to wallets file (optional, defaults to config/wallets.txt)
# WALLETS_FILE=/path/to/wallets.txt
SUPABASE_URL=https://your-project-ref.supabase.co
# Replace <db-password> with the Postgres password from Supabase.
SUPABASE_DB_URL=postgresql://postgres:<db-password>@db.your-project-ref.supabase.co:5432/postgres?sslmode=require

